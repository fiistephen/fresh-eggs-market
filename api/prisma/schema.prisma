// Fresh Eggs Operations Management System
// Database Schema — the single source of truth for all data

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── AUTH & USERS ──────────────────────────────────────────────

enum Role {
  ADMIN
  MANAGER
  SHOP_FLOOR
  RECORD_KEEPER
  CUSTOMER
}

model User {
  id           String   @id @default(cuid())
  email        String?  @unique
  passwordHash String   @map("password_hash")
  firstName    String   @map("first_name")
  lastName     String   @map("last_name")
  phone        String?  @unique
  role         Role     @default(CUSTOMER)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  refreshTokens  RefreshToken[]
  salesRecorded    Sale[]              @relation("SaleRecordedBy")
  salesLimitOverrides Sale[]           @relation("SaleLimitOverrideBy")
  bankTransactions BankTransaction[]   @relation("TransactionEnteredBy")
  inventoryCounts  InventoryCount[]    @relation("CountEnteredBy")
  statementImports BankStatementImport[] @relation("StatementImportedBy")
  reconciliations  BankReconciliation[]  @relation("ReconciledBy")
  bookingAllocations BookingPaymentAllocation[] @relation("AllocationCreatedBy")
  appSettingsUpdated AppSetting[] @relation("AppSettingUpdatedBy")
  cashDepositBatchesCreated CashDepositBatch[] @relation("CashDepositBatchCreatedBy")
  cashDepositBatchesConfirmed CashDepositBatch[] @relation("CashDepositBatchConfirmedBy")
  portalCheckoutsAdminConfirmed PortalCheckout[] @relation("PortalCheckoutAdminConfirmedBy")
  portalCheckoutDecisions PortalCheckoutDecision[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// ─── CUSTOMERS ─────────────────────────────────────────────────

model Customer {
  id          String   @id @default(cuid())
  name        String
  phone       String   @unique
  email       String?
  isFirstTime Boolean  @default(true) @map("is_first_time")
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  bookings         Booking[]
  portalOrderRequests PortalOrderRequest[]
  portalCheckouts  PortalCheckout[]
  sales            Sale[]
  bankTransactions BankTransaction[]
  statementLines   BankStatementLine[]

  @@map("customers")
}

// ─── BATCHES ───────────────────────────────────────────────────

enum BatchStatus {
  OPEN       // Created, accepting bookings, not yet received
  RECEIVED   // Eggs arrived at depot, sales can happen
  CLOSED     // Fully sold or manually closed
}

model Batch {
  id                    String      @id @default(cuid())
  name                  String      @unique // e.g. "8APR2026", "12JUN2026A"
  expectedDate          DateTime    @map("expected_date")
  receivedDate          DateTime?   @map("received_date")
  closedDate            DateTime?   @map("closed_date")
  status                BatchStatus @default(OPEN)

  expectedQuantity      Int         @map("expected_quantity")      // Total crates expected (paid)
  availableForBooking   Int         @map("available_for_booking")  // How many can be booked
  actualQuantity        Int?        @map("actual_quantity")        // Actual received (paid + free)
  freeCrates            Int         @default(3) @map("free_crates") // Free crates from farm (usually 3)
  eggTypeKey            String      @default("REGULAR") @map("egg_type_key")

  wholesalePrice        Decimal     @map("wholesale_price") @db.Decimal(12, 2)
  retailPrice           Decimal     @map("retail_price")   @db.Decimal(12, 2)
  costPrice             Decimal     @map("cost_price")     @db.Decimal(12, 2) // Default cost; specific codes may differ

  createdAt             DateTime    @default(now()) @map("created_at")
  updatedAt             DateTime    @updatedAt @map("updated_at")

  eggCodes    BatchEggCode[]
  bookings    Booking[]
  portalOrderRequests PortalOrderRequest[]
  portalCheckouts PortalCheckout[]
  sales       Sale[]
  inventory   InventoryCount[]

  @@map("batches")
}

// Egg codes within a batch — e.g. FE4600 (1000 crates) + FE4800 (800 crates)
model BatchEggCode {
  id             String   @id @default(cuid())
  batchId        String   @map("batch_id")
  itemId         String?  @map("item_id")
  code           String   // e.g. "FE4600"
  costPrice      Decimal  @map("cost_price") @db.Decimal(12, 2) // ₦ per crate for this code
  wholesalePrice Decimal? @map("wholesale_price") @db.Decimal(12, 2)
  retailPrice    Decimal? @map("retail_price") @db.Decimal(12, 2)
  quantity       Int      // Paid crates of this code
  freeQty        Int      @default(0) @map("free_qty") // Free crates of this code

  batch Batch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  item  Item? @relation(fields: [itemId], references: [id])

  bookings      Booking[]
  saleLineItems SaleLineItem[]

  @@unique([batchId, code])
  @@map("batch_egg_codes")
}

enum ItemCategory {
  FE_EGGS
  CRATES
  DELIVERY
  LEGACY_MISC
}

model Item {
  id                    String       @id @default(cuid())
  code                  String?      @unique
  name                  String
  category              ItemCategory @default(FE_EGGS)
  unitLabel             String       @default("crate") @map("unit_label")
  description           String?
  defaultWholesalePrice Decimal?     @map("default_wholesale_price") @db.Decimal(12, 2)
  defaultRetailPrice    Decimal?     @map("default_retail_price") @db.Decimal(12, 2)
  isActive              Boolean      @default(true) @map("is_active")
  createdAt             DateTime     @default(now()) @map("created_at")
  updatedAt             DateTime     @updatedAt @map("updated_at")

  batchEggCodes         BatchEggCode[]

  @@map("items")
}

// ─── BOOKINGS ──────────────────────────────────────────────────

enum BookingStatus {
  CONFIRMED   // Paid and booked
  PICKED_UP   // Customer collected eggs (becomes a sale)
  CANCELLED   // Cancelled, refund issued
}

enum PortalOrderRequestStatus {
  OPEN
  AWAITING_PAYMENT
  PENDING_TRANSFER_CONFIRMATION
  APPROVED_FOR_PICKUP
  FULFILLED
  REJECTED
  CANCELLED
}

enum PortalPaymentMethod {
  CARD
  TRANSFER
}

enum PortalPaymentStatus {
  AWAITING_PAYMENT
  AWAITING_TRANSFER
  PAID
  FAILED
  CANCELLED
}

enum PortalOrderRequestType {
  BUY_NOW
}

enum PortalPriceType {
  WHOLESALE
  RETAIL
}

model Booking {
  id             String        @id @default(cuid())
  customerId     String        @map("customer_id")
  batchId        String        @map("batch_id")
  batchEggCodeId String?       @map("batch_egg_code_id")
  quantity       Int           // Crates booked
  amountPaid     Decimal       @map("amount_paid") @db.Decimal(12, 2)
  orderValue     Decimal       @map("order_value") @db.Decimal(12, 2) // Full value at booking price
  status         BookingStatus @default(CONFIRMED)
  channel        String        @default("backend") // "website" or "backend"
  notes          String?
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  customer Customer @relation(fields: [customerId], references: [id])
  batch    Batch    @relation(fields: [batchId], references: [id])
  batchEggCode BatchEggCode? @relation(fields: [batchEggCodeId], references: [id])
  sale     Sale?    // Linked when booking is picked up and converted to sale
  allocations BookingPaymentAllocation[]
  portalCheckout PortalCheckout?

  @@map("bookings")
}

model PortalOrderRequest {
  id             String                   @id @default(cuid())
  customerId     String                   @map("customer_id")
  batchId        String                   @map("batch_id")
  requestType    PortalOrderRequestType   @default(BUY_NOW) @map("request_type")
  status         PortalOrderRequestStatus @default(OPEN)
  paymentMethod  PortalPaymentMethod      @default(CARD) @map("payment_method")
  paymentStatus  PortalPaymentStatus      @default(PAID) @map("payment_status")
  quantity       Int
  priceType      PortalPriceType          @map("price_type")
  unitPrice      Decimal                  @map("unit_price") @db.Decimal(12, 2)
  estimatedTotal Decimal                  @map("estimated_total") @db.Decimal(12, 2)
  amountPaid     Decimal                  @default(0) @map("amount_paid") @db.Decimal(12, 2)
  paymentReference String?                @unique @map("payment_reference")
  pickupWindowStart DateTime?             @map("pickup_window_start")
  pickupWindowEnd DateTime?               @map("pickup_window_end")
  notes          String?
  createdAt      DateTime                 @default(now()) @map("created_at")
  updatedAt      DateTime                 @updatedAt @map("updated_at")

  customer Customer @relation(fields: [customerId], references: [id])
  batch    Batch    @relation(fields: [batchId], references: [id])
  checkout PortalCheckout?

  @@map("portal_order_requests")
}

enum PortalCheckoutType {
  BOOK_UPCOMING
  BUY_NOW
}

enum PortalCheckoutStatus {
  AWAITING_PAYMENT
  AWAITING_TRANSFER
  ADMIN_CONFIRMED
  PAID
  FAILED
  CANCELLED
}

enum PortalCheckoutDecisionType {
  APPROVED
  REJECTED
  MONEY_SEEN
  STATEMENT_CONFIRMED
}

model PortalCheckout {
  id                   String                   @id @default(cuid())
  customerId           String                   @map("customer_id")
  batchId              String                   @map("batch_id")
  bookingId            String?                  @unique @map("booking_id")
  portalOrderRequestId String?                  @unique @map("portal_order_request_id")
  checkoutType         PortalCheckoutType       @map("checkout_type")
  paymentMethod        PortalPaymentMethod      @map("payment_method")
  status               PortalCheckoutStatus     @default(AWAITING_PAYMENT)
  quantity             Int
  priceType            PortalPriceType?         @map("price_type")
  unitPrice            Decimal?                 @map("unit_price") @db.Decimal(12, 2)
  orderValue           Decimal                  @map("order_value") @db.Decimal(12, 2)
  amountToPay          Decimal                  @map("amount_to_pay") @db.Decimal(12, 2)
  balanceAfterPayment  Decimal                  @map("balance_after_payment") @db.Decimal(12, 2)
  reference            String                   @unique
  paystackReference    String?                  @unique @map("paystack_reference")
  paystackAccessCode   String?                  @map("paystack_access_code")
  paystackAuthorizationUrl String?              @map("paystack_authorization_url")
  paymentWindowEndsAt  DateTime?                @map("payment_window_ends_at")
  pickupWindowStart    DateTime?                @map("pickup_window_start")
  pickupWindowEnd      DateTime?                @map("pickup_window_end")
  adminConfirmedById   String?                  @map("admin_confirmed_by_id")
  adminConfirmedAt     DateTime?                @map("admin_confirmed_at")
  confirmationStatementLineId String?           @unique @map("confirmation_statement_line_id")
  notes                String?
  verifiedAt           DateTime?                @map("verified_at")
  createdAt            DateTime                 @default(now()) @map("created_at")
  updatedAt            DateTime                 @updatedAt @map("updated_at")

  customer             Customer                 @relation(fields: [customerId], references: [id])
  batch                Batch                    @relation(fields: [batchId], references: [id])
  booking              Booking?                 @relation(fields: [bookingId], references: [id])
  portalOrderRequest   PortalOrderRequest?      @relation(fields: [portalOrderRequestId], references: [id])
  adminConfirmedBy     User?                    @relation("PortalCheckoutAdminConfirmedBy", fields: [adminConfirmedById], references: [id])
  selectedStatementLine BankStatementLine?      @relation("BankStatementLineSelectedPortalCheckout")
  confirmationStatementLine BankStatementLine?  @relation("PortalCheckoutConfirmedStatementLine", fields: [confirmationStatementLineId], references: [id])
  decisions            PortalCheckoutDecision[]

  @@map("portal_checkouts")
}

model PortalCheckoutDecision {
  id           String                     @id @default(cuid())
  portalCheckoutId String                 @map("portal_checkout_id")
  actorId      String                     @map("actor_id")
  decisionType PortalCheckoutDecisionType @map("decision_type")
  statusBefore PortalCheckoutStatus?      @map("status_before")
  statusAfter  PortalCheckoutStatus?      @map("status_after")
  notes        String?
  createdAt    DateTime                   @default(now()) @map("created_at")

  portalCheckout PortalCheckout @relation(fields: [portalCheckoutId], references: [id], onDelete: Cascade)
  actor          User           @relation(fields: [actorId], references: [id])

  @@index([portalCheckoutId, createdAt])
  @@index([actorId, createdAt])
  @@map("portal_checkout_decisions")
}

// ─── SALES ─────────────────────────────────────────────────────

enum SaleType {
  WHOLESALE
  RETAIL
  CRACKED       // Sold below cost
  WRITE_OFF     // Zero price / unsellable
}

enum PaymentMethod {
  CASH
  TRANSFER
  POS_CARD    // Card via POS machine
  PRE_ORDER   // Already paid via booking deposit
  MIXED       // Settled with more than one payment method
}

model Sale {
  id             String        @id @default(cuid())
  receiptNumber  String        @unique @map("receipt_number") // Auto-generated
  customerId     String        @map("customer_id")
  batchId        String?       @map("batch_id")
  bookingId      String?       @unique @map("booking_id") // If fulfilling a booking
  recordedById   String        @map("recorded_by_id")
  limitOverrideNote String?    @map("limit_override_note")
  limitOverrideById String?    @map("limit_override_by_id")
  limitOverrideAt DateTime?    @map("limit_override_at")

  totalQuantity  Int           @map("total_quantity")
  totalAmount    Decimal       @map("total_amount") @db.Decimal(12, 2)
  totalCost      Decimal       @map("total_cost")   @db.Decimal(12, 2)
  paymentMethod  PaymentMethod @map("payment_method")
  saleDate       DateTime      @default(now()) @map("sale_date")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  customer   Customer      @relation(fields: [customerId], references: [id])
  batch      Batch?        @relation(fields: [batchId], references: [id])
  booking    Booking?      @relation(fields: [bookingId], references: [id])
  recordedBy User          @relation("SaleRecordedBy", fields: [recordedById], references: [id])
  limitOverrideBy User?    @relation("SaleLimitOverrideBy", fields: [limitOverrideById], references: [id])
  lineItems  SaleLineItem[]
  paymentTransactions BankTransaction[] @relation("SalePaymentTransactions")

  @@map("sales")
}

model SaleLineItem {
  id              String   @id @default(cuid())
  saleId          String   @map("sale_id")
  batchEggCodeId  String   @map("batch_egg_code_id")
  saleType        SaleType @map("sale_type")
  quantity        Int
  unitPrice       Decimal  @map("unit_price") @db.Decimal(12, 2)  // Actual selling price per crate
  costPrice       Decimal  @map("cost_price") @db.Decimal(12, 2)  // Cost price per crate (from egg code)
  lineTotal       Decimal  @map("line_total") @db.Decimal(12, 2)  // quantity * unitPrice

  sale         Sale         @relation(fields: [saleId], references: [id], onDelete: Cascade)
  batchEggCode BatchEggCode @relation(fields: [batchEggCodeId], references: [id])

  @@map("sale_line_items")
}

// ─── BANKING ───────────────────────────────────────────────────

enum BankAccountType {
  CUSTOMER_DEPOSIT  // Ends in 10, publicly known
  SALES             // Funded weekly from customer deposit
  PROFIT            // Funded monthly from sales, pays all expenses
  CASH_ON_HAND      // Virtual cash ledger for cash sales before banking
}

model BankAccount {
  id           String          @id @default(cuid())
  name         String          // Display name e.g. "Customer Deposit Account"
  accountType  BankAccountType @map("account_type")
  lastFour     String          @map("last_four") // Last 4 digits for display
  bankName     String          @default("Providus Bank") @map("bank_name")
  isActive     Boolean         @default(true) @map("is_active")
  isVirtual    Boolean         @default(false) @map("is_virtual")
  supportsStatementImport Boolean @default(true) @map("supports_statement_import")
  sortOrder    Int             @default(0) @map("sort_order")
  createdAt    DateTime        @default(now()) @map("created_at")

  transactions BankTransaction[]
  statementImports BankStatementImport[]
  reconciliations BankReconciliation[]
  cashDepositBatchesFrom CashDepositBatch[] @relation("CashDepositBatchFromAccount")
  cashDepositBatchesTo CashDepositBatch[]   @relation("CashDepositBatchToAccount")

  @@map("bank_accounts")
}

enum TransactionDirection {
  INFLOW
  OUTFLOW
}

enum TransactionSourceType {
  MANUAL
  STATEMENT_IMPORT
  INTERNAL_TRANSFER
  CASH_DEPOSIT
  SYSTEM
}

enum StatementProvider {
  PROVIDUS
}

enum StatementImportStatus {
  DRAFT
  REVIEWING
  POSTED
  PARTIALLY_POSTED
  CANCELLED
}

enum StatementLineReviewStatus {
  PENDING_REVIEW
  READY_TO_POST
  POSTED
  SKIPPED
  DUPLICATE
}

enum ReconciliationStatus {
  BALANCED
  VARIANCE
  OPEN
}

enum CashDepositBatchStatus {
  PENDING_CONFIRMATION
  CONFIRMED
  OVERDUE
  REJECTED
  CANCELLED
}

model BankTransaction {
  id              String               @id @default(cuid())
  bankAccountId   String               @map("bank_account_id")
  direction       TransactionDirection
  category        String
  amount          Decimal              @db.Decimal(12, 2)
  description     String?
  reference       String?              // Bank reference / narration
  transactionDate DateTime             @map("transaction_date")
  sourceType      TransactionSourceType @default(MANUAL) @map("source_type")
  sourceFingerprint String?            @unique @map("source_fingerprint")
  internalTransferGroupId String?      @map("internal_transfer_group_id")
  postedAt        DateTime?            @map("posted_at")

  // Optional links — depends on category
  saleId          String?              @map("sale_id")
  customerId      String?              @map("customer_id")
  bookingId       String?              @map("booking_id_ref") // For CUSTOMER_BOOKING category
  enteredById     String               @map("entered_by_id")

  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")

  bankAccount BankAccount @relation(fields: [bankAccountId], references: [id])
  sale        Sale?       @relation("SalePaymentTransactions", fields: [saleId], references: [id])
  customer    Customer?   @relation(fields: [customerId], references: [id])
  enteredBy   User        @relation("TransactionEnteredBy", fields: [enteredById], references: [id])
  statementLine BankStatementLine?
  allocations BookingPaymentAllocation[]
  cashDepositBatchLinks CashDepositBatchTransaction[]
  cashDepositOutflow CashDepositBatch? @relation("CashDepositBatchOutflow")

  @@map("bank_transactions")
}

model BankStatementImport {
  id               String               @id @default(cuid())
  bankAccountId    String               @map("bank_account_id")
  provider         StatementProvider
  originalFilename String               @map("original_filename")
  statementDateFrom DateTime?           @map("statement_date_from")
  statementDateTo   DateTime?           @map("statement_date_to")
  openingBalance   Decimal?             @map("opening_balance") @db.Decimal(14, 2)
  closingBalance   Decimal?             @map("closing_balance") @db.Decimal(14, 2)
  status           StatementImportStatus @default(REVIEWING)
  rawRowCount      Int                  @default(0) @map("raw_row_count")
  parsedRowCount   Int                  @default(0) @map("parsed_row_count")
  postedRowCount   Int                  @default(0) @map("posted_row_count")
  importedById     String               @map("imported_by_id")
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")

  bankAccount      BankAccount          @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  importedBy       User                 @relation("StatementImportedBy", fields: [importedById], references: [id])
  lines            BankStatementLine[]
  reconciliations  BankReconciliation[]

  @@map("bank_statement_imports")
}

model BankStatementLine {
  id                 String                    @id @default(cuid())
  importId           String                    @map("import_id")
  lineNumber         Int                       @map("line_number")
  transactionDate    DateTime?                 @map("transaction_date")
  actualTransactionDate DateTime?              @map("actual_transaction_date")
  valueDate          DateTime?                 @map("value_date")
  description        String
  docNum             String?                   @map("doc_num")
  debitAmount        Decimal?                  @map("debit_amount") @db.Decimal(14, 2)
  creditAmount       Decimal?                  @map("credit_amount") @db.Decimal(14, 2)
  runningBalance     Decimal?                  @map("running_balance") @db.Decimal(14, 2)
  direction          TransactionDirection?
  reviewStatus       StatementLineReviewStatus @default(PENDING_REVIEW) @map("review_status")
  suggestedCategory  String?                   @map("suggested_category")
  selectedCategory   String?                   @map("selected_category")
  selectedCustomerId String?                   @map("selected_customer_id")
  matchedCashDepositBatchId String?            @map("matched_cash_deposit_batch_id")
  selectedPortalCheckoutId String?             @unique @map("selected_portal_checkout_id")
  notes              String?
  fingerprint        String                    @unique
  postedTransactionId String?                  @unique @map("posted_transaction_id")
  rawPayload         Json?                     @map("raw_payload")
  createdAt          DateTime                  @default(now()) @map("created_at")
  updatedAt          DateTime                  @updatedAt @map("updated_at")

  import            BankStatementImport @relation(fields: [importId], references: [id], onDelete: Cascade)
  selectedCustomer  Customer?           @relation(fields: [selectedCustomerId], references: [id])
  postedTransaction BankTransaction?    @relation(fields: [postedTransactionId], references: [id])
  matchedCashDepositBatch CashDepositBatch? @relation("CashDepositBatchMatchedStatementLine", fields: [matchedCashDepositBatchId], references: [id])
  confirmedCashDepositBatch CashDepositBatch? @relation("CashDepositBatchConfirmedStatementLine")
  selectedPortalCheckout PortalCheckout? @relation("BankStatementLineSelectedPortalCheckout", fields: [selectedPortalCheckoutId], references: [id])
  confirmedPortalCheckout PortalCheckout? @relation("PortalCheckoutConfirmedStatementLine")

  @@unique([importId, lineNumber])
  @@map("bank_statement_lines")
}

model BankReconciliation {
  id                String               @id @default(cuid())
  bankAccountId     String               @map("bank_account_id")
  statementImportId String?              @map("statement_import_id")
  statementDate     DateTime             @map("statement_date")
  openingBalance    Decimal?             @map("opening_balance") @db.Decimal(14, 2)
  closingBalance    Decimal              @map("closing_balance") @db.Decimal(14, 2)
  systemBalance     Decimal              @map("system_balance") @db.Decimal(14, 2)
  variance          Decimal              @db.Decimal(14, 2)
  status            ReconciliationStatus @default(OPEN)
  notes             String?
  reconciledById    String               @map("reconciled_by_id")
  createdAt         DateTime             @default(now()) @map("created_at")

  bankAccount       BankAccount          @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  statementImport   BankStatementImport? @relation(fields: [statementImportId], references: [id])
  reconciledBy      User                 @relation("ReconciledBy", fields: [reconciledById], references: [id])

  @@map("bank_reconciliations")
}

model BookingPaymentAllocation {
  id              String   @id @default(cuid())
  bookingId       String   @map("booking_id")
  bankTransactionId String @map("bank_transaction_id")
  amount          Decimal  @db.Decimal(12, 2)
  allocatedById   String   @map("allocated_by_id")
  createdAt       DateTime @default(now()) @map("created_at")

  booking         Booking         @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  bankTransaction BankTransaction @relation(fields: [bankTransactionId], references: [id], onDelete: Cascade)
  allocatedBy     User            @relation("AllocationCreatedBy", fields: [allocatedById], references: [id])

  @@unique([bookingId, bankTransactionId])
  @@map("booking_payment_allocations")
}

model CashDepositBatch {
  id                          String                 @id @default(cuid())
  fromBankAccountId           String                 @map("from_bank_account_id")
  toBankAccountId             String                 @map("to_bank_account_id")
  outflowTransactionId        String                 @unique @map("outflow_transaction_id")
  amount                      Decimal                @db.Decimal(12, 2)
  depositDate                 DateTime               @map("deposit_date")
  status                      CashDepositBatchStatus @default(PENDING_CONFIRMATION)
  createdById                 String                 @map("created_by_id")
  confirmedById               String?                @map("confirmed_by_id")
  confirmedAt                 DateTime?              @map("confirmed_at")
  confirmationStatementLineId String?                @unique @map("confirmation_statement_line_id")
  notes                       String?
  createdAt                   DateTime               @default(now()) @map("created_at")
  updatedAt                   DateTime               @updatedAt @map("updated_at")

  fromBankAccount             BankAccount            @relation("CashDepositBatchFromAccount", fields: [fromBankAccountId], references: [id])
  toBankAccount               BankAccount            @relation("CashDepositBatchToAccount", fields: [toBankAccountId], references: [id])
  outflowTransaction          BankTransaction        @relation("CashDepositBatchOutflow", fields: [outflowTransactionId], references: [id])
  createdBy                   User                   @relation("CashDepositBatchCreatedBy", fields: [createdById], references: [id])
  confirmedBy                 User?                  @relation("CashDepositBatchConfirmedBy", fields: [confirmedById], references: [id])
  confirmationStatementLine   BankStatementLine?     @relation("CashDepositBatchConfirmedStatementLine", fields: [confirmationStatementLineId], references: [id])
  transactions                CashDepositBatchTransaction[]
  matchedStatementLines       BankStatementLine[]    @relation("CashDepositBatchMatchedStatementLine")

  @@map("cash_deposit_batches")
}

model CashDepositBatchTransaction {
  id                 String           @id @default(cuid())
  cashDepositBatchId String           @map("cash_deposit_batch_id")
  bankTransactionId  String           @map("bank_transaction_id")
  amountIncluded     Decimal          @map("amount_included") @db.Decimal(12, 2)
  createdAt          DateTime         @default(now()) @map("created_at")

  cashDepositBatch   CashDepositBatch @relation(fields: [cashDepositBatchId], references: [id], onDelete: Cascade)
  bankTransaction    BankTransaction  @relation(fields: [bankTransactionId], references: [id], onDelete: Cascade)

  @@unique([cashDepositBatchId, bankTransactionId])
  @@map("cash_deposit_batch_transactions")
}

// ─── INVENTORY ─────────────────────────────────────────────────

model InventoryCount {
  id             String   @id @default(cuid())
  batchId        String   @map("batch_id")
  countDate      DateTime @map("count_date")
  physicalCount  Int      @map("physical_count")  // What staff counted on the floor
  systemCount    Int      @map("system_count")     // What the system thinks it should be
  discrepancy    Int      @default(0)              // physicalCount - systemCount
  crackedWriteOff Int     @default(0) @map("cracked_write_off") // Crates written off as unsellable
  notes          String?
  enteredById    String   @map("entered_by_id")
  createdAt      DateTime @default(now()) @map("created_at")

  batch     Batch @relation(fields: [batchId], references: [id])
  enteredBy User  @relation("CountEnteredBy", fields: [enteredById], references: [id])

  @@unique([batchId, countDate])
  @@map("inventory_counts")
}

model AppSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Json
  description String?
  updatedById String?  @map("updated_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  updatedBy   User?    @relation("AppSettingUpdatedBy", fields: [updatedById], references: [id])

  @@map("app_settings")
}
